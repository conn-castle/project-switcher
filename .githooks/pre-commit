#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Determine which test targets are affected by staged files.
# Includes both added/modified AND deleted files, since deleting source
# can break compilation or tests in the affected target.
targets=()
run_all=false

while IFS= read -r file; do
  case "$file" in
    ProjectSwitcherApp/*|ProjectSwitcherAppTests/*)
      targets+=("ProjectSwitcherAppTests")
      ;;
    ProjectSwitcherAppKit/*)
      targets+=("ProjectSwitcherCoreTests")
      targets+=("ProjectSwitcherAppTests")
      targets+=("ProjectSwitcherCLITests")
      ;;
    ProjectSwitcherCore/*|ProjectSwitcherCoreTests/*)
      targets+=("ProjectSwitcherCoreTests")
      targets+=("ProjectSwitcherAppTests")
      targets+=("ProjectSwitcherCLITests")
      ;;
    ProjectSwitcherCLI/*|ProjectSwitcherCLICore/*|ProjectSwitcherCLITests/*)
      targets+=("ProjectSwitcherCLITests")
      ;;
    project.yml|Makefile|scripts/*|*.xcodeproj/*|*.xcscheme|TestPlans/*)
      run_all=true
      ;;
  esac
done < <(git diff --cached --name-only)

if "$run_all"; then
  echo "pre-commit: infrastructure files changed — running all tests..."
  scripts/test.sh
  exit 0
fi

# Deduplicate targets
unique_targets=()
while IFS= read -r t; do
  [[ -n "$t" ]] && unique_targets+=("$t")
done < <(printf '%s\n' "${targets[@]}" 2>/dev/null | sort -u)

if [[ ${#unique_targets[@]} -eq 0 ]]; then
  echo "pre-commit: no source changes staged — skipping tests."
  exit 0
fi

for t in "${unique_targets[@]}"; do
  echo "pre-commit: running $t..."
  scripts/test.sh --target "$t"
done
